<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AS Level Macroeconomics — Knowledge Test</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d1117;
    --bg2: #161b22;
    --bg3: #21262d;
    --ink: #e6edf3;
    --ink2: #c9d1d9;
    --muted: #8b949e;
    --accent: #f78166;
    --accent2: #79c0ff;
    --accent3: #56d364;
    --card: #161b22;
    --border: #30363d;
    --correct: #56d364;
    --correct-bg: rgba(86,211,100,0.08);
    --wrong: #f85149;
    --wrong-bg: rgba(248,81,73,0.08);
    --tag-demand: rgba(251,191,36,0.12);
    --tag-demand-border: #d4a017;
    --tag-supply: rgba(86,211,100,0.12);
    --tag-supply-border: #3fb950;
    --tag-failure: rgba(248,81,73,0.12);
    --tag-failure-border: #f85149;
    --tag-policy: rgba(121,192,255,0.12);
    --tag-policy-border: #79c0ff;
    --tag-behav: rgba(188,140,255,0.12);
    --tag-behav-border: #bc8cff;
    --tag-found: rgba(247,129,102,0.12);
    --tag-found-border: #f78166;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--ink2);
    font-family: 'Outfit', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 15px;
    line-height: 1.65;
  }

  /* SIDEBAR */
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 240px;
    height: 100vh;
    background: var(--bg2);
    border-right: 1px solid var(--border);
    color: var(--ink2);
    overflow-y: auto;
    padding: 24px 0;
    z-index: 100;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); }

  .sidebar-title {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 18px;
    padding: 0 20px 20px;
    border-bottom: 1px solid var(--border);
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .sidebar-title span {
    display: block;
    font-family: 'Outfit', sans-serif;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: 4px;
  }

  .sidebar-section {
    padding: 16px 20px 4px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .sidebar a {
    display: block;
    padding: 6px 20px;
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 400;
    transition: all 0.15s;
    border-left: 2px solid transparent;
    line-height: 1.4;
  }
  .sidebar a:hover, .sidebar a.active {
    color: var(--ink);
    background: var(--bg3);
    border-left-color: var(--accent2);
  }
  .sidebar a.quiz-active {
    color: var(--accent2);
    border-left-color: var(--accent2);
  }

  /* MAIN */
  .main {
    margin-left: 240px;
    padding: 48px 60px 80px;
    max-width: 1100px;
  }

  /* HERO */
  .hero {
    margin-bottom: 52px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--border);
  }
  .hero-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: 12px;
  }
  .hero h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 42px;
    color: var(--ink);
    line-height: 1.15;
    margin-bottom: 14px;
  }
  .hero p {
    color: var(--muted);
    font-size: 15px;
    max-width: 560px;
  }

  /* TOPIC SELECTOR */
  .selector-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }

  .topic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
    margin-bottom: 48px;
  }

  .topic-btn {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
    cursor: pointer;
    transition: all 0.15s;
    text-align: left;
    color: var(--ink2);
    font-family: 'Outfit', sans-serif;
  }
  .topic-btn:hover {
    border-color: var(--accent2);
    background: var(--bg3);
    transform: translateY(-1px);
  }
  .topic-btn.selected {
    border-color: var(--accent2);
    background: rgba(121,192,255,0.06);
  }
  .topic-btn .t-num {
    font-family: 'DM Mono', 'SFMono-Regular', monospace;
    font-size: 10px;
    color: var(--accent2);
    letter-spacing: 0.08em;
    margin-bottom: 6px;
    display: block;
  }
  .topic-btn .t-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.35;
  }
  .topic-btn .t-count {
    font-size: 11px;
    color: var(--muted);
    margin-top: 6px;
  }

  .start-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent2);
    color: #0d1117;
    border: none;
    border-radius: 6px;
    padding: 12px 28px;
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.02em;
  }
  .start-btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .start-btn:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }

  /* QUIZ AREA */
  .quiz-area { display: none; }
  .quiz-area.active { display: block; }
  .selector-area.hidden { display: none; }

  .quiz-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 36px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
    gap: 16px;
  }
  .quiz-header-left h2 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 28px;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .quiz-header-left p {
    font-size: 13px;
    color: var(--muted);
  }

  .progress-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    min-width: 160px;
  }
  .progress-label {
    font-size: 12px;
    color: var(--muted);
    font-family: 'DM Mono', monospace;
  }
  .progress-bar {
    width: 160px;
    height: 4px;
    background: var(--bg3);
    border-radius: 2px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--accent2);
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  /* QUESTION CARD */
  .question-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px 36px;
    margin-bottom: 20px;
    animation: fadeUp 0.25s ease;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .q-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }
  .q-num {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
  }
  .q-type-badge {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
    border: 1px solid;
  }
  .q-type-badge.mc   { background: var(--tag-policy); border-color: var(--tag-policy-border); color: var(--accent2); }
  .q-type-badge.tf   { background: var(--tag-supply); border-color: var(--tag-supply-border); color: var(--accent3); }
  .q-type-badge.short{ background: var(--tag-behav);  border-color: var(--tag-behav-border);  color: #bc8cff; }

  .q-text {
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.5;
    margin-bottom: 24px;
  }

  /* MC OPTIONS */
  .options-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .option-btn {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 13px 18px;
    cursor: pointer;
    text-align: left;
    color: var(--ink2);
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    transition: all 0.12s;
    display: flex;
    align-items: center;
    gap: 12px;
    width: 100%;
  }
  .option-btn:hover:not(:disabled) {
    border-color: var(--accent2);
    background: rgba(121,192,255,0.05);
  }
  .option-btn .opt-letter {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    min-width: 16px;
  }
  .option-btn.correct {
    border-color: var(--correct);
    background: var(--correct-bg);
    color: var(--correct);
  }
  .option-btn.correct .opt-letter { color: var(--correct); }
  .option-btn.wrong {
    border-color: var(--wrong);
    background: var(--wrong-bg);
    color: var(--wrong);
  }
  .option-btn.wrong .opt-letter { color: var(--wrong); }
  .option-btn:disabled { cursor: default; }

  /* TRUE/FALSE */
  .tf-options { display: flex; gap: 12px; }
  .tf-btn {
    flex: 1;
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 15px;
    font-weight: 500;
    transition: all 0.12s;
    color: var(--ink2);
  }
  .tf-btn:hover:not(:disabled) {
    border-color: var(--accent2);
    background: rgba(121,192,255,0.05);
  }
  .tf-btn.correct {
    border-color: var(--correct);
    background: var(--correct-bg);
    color: var(--correct);
  }
  .tf-btn.wrong {
    border-color: var(--wrong);
    background: var(--wrong-bg);
    color: var(--wrong);
  }
  .tf-btn:disabled { cursor: default; }

  /* SHORT ANSWER */
  .short-answer-wrap { display: flex; flex-direction: column; gap: 10px; }
  .short-input {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 13px 16px;
    color: var(--ink);
    font-family: 'Outfit', sans-serif;
    font-size: 14px;
    resize: vertical;
    min-height: 80px;
    transition: border-color 0.12s;
    width: 100%;
  }
  .short-input:focus {
    outline: none;
    border-color: var(--accent2);
  }
  .short-input:disabled {
    opacity: 0.7;
    cursor: default;
  }
  .check-btn {
    align-self: flex-start;
    background: var(--bg3);
    border: 1px solid var(--accent2);
    color: var(--accent2);
    border-radius: 6px;
    padding: 9px 20px;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.12s;
  }
  .check-btn:hover { background: rgba(121,192,255,0.08); }

  /* FEEDBACK */
  .feedback-box {
    margin-top: 16px;
    padding: 14px 18px;
    border-radius: 8px;
    font-size: 14px;
    line-height: 1.55;
    display: none;
  }
  .feedback-box.show { display: block; animation: fadeUp 0.2s ease; }
  .feedback-box.correct-fb {
    background: var(--correct-bg);
    border: 1px solid rgba(86,211,100,0.25);
    color: var(--correct);
  }
  .feedback-box.wrong-fb {
    background: var(--wrong-bg);
    border: 1px solid rgba(248,81,73,0.25);
    color: var(--ink2);
  }
  .feedback-box .fb-label {
    font-weight: 600;
    margin-bottom: 4px;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .feedback-box.correct-fb .fb-label { color: var(--correct); }
  .feedback-box.wrong-fb .fb-label { color: var(--wrong); }
  .model-answer {
    color: var(--ink2);
    font-size: 14px;
    margin-top: 4px;
  }

  /* NAV BUTTONS */
  .q-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 28px;
  }
  .nav-btn {
    background: var(--bg2);
    border: 1px solid var(--border);
    color: var(--ink2);
    border-radius: 6px;
    padding: 10px 22px;
    font-family: 'Outfit', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.12s;
  }
  .nav-btn:hover { border-color: var(--accent2); color: var(--ink); }
  .nav-btn:disabled { opacity: 0.3; cursor: default; border-color: var(--border); }
  .nav-btn.primary {
    background: var(--accent2);
    border-color: var(--accent2);
    color: #0d1117;
    font-weight: 600;
  }
  .nav-btn.primary:hover { opacity: 0.88; }

  /* RESULTS */
  .results-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 48px;
    text-align: center;
    animation: fadeUp 0.3s ease;
  }
  .score-ring {
    width: 120px;
    height: 120px;
    margin: 0 auto 28px;
    position: relative;
  }
  .score-ring svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .score-ring circle {
    fill: none;
    stroke-width: 6;
  }
  .ring-bg { stroke: var(--bg3); }
  .ring-fill { stroke: var(--accent2); stroke-linecap: round; transition: stroke-dashoffset 1s ease; }
  .ring-fill.high { stroke: var(--correct); }
  .ring-fill.low  { stroke: var(--wrong); }
  .score-text {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Instrument Serif', serif;
    font-size: 28px;
    color: var(--ink);
  }
  .results-title {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 30px;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .results-sub {
    color: var(--muted);
    font-size: 14px;
    margin-bottom: 36px;
  }

  .results-breakdown {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 36px;
    text-align: left;
  }
  .rb-item {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 18px;
  }
  .rb-item .rb-val {
    font-family: 'DM Mono', monospace;
    font-size: 24px;
    color: var(--ink);
    margin-bottom: 2px;
  }
  .rb-item .rb-label {
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .results-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .results-actions .nav-btn { padding: 11px 26px; font-size: 14px; }

  /* REVIEW SECTION */
  .review-list { margin-top: 40px; }
  .review-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .review-item {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    margin-bottom: 12px;
    border-left: 3px solid var(--border);
  }
  .review-item.r-correct { border-left-color: var(--correct); }
  .review-item.r-wrong   { border-left-color: var(--wrong); }
  .review-item .r-q {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 8px;
  }
  .review-item .r-your {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .review-item .r-correct-ans {
    font-size: 13px;
    color: var(--correct);
  }
  .review-item .r-status {
    float: right;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 3px;
  }
  .r-correct .r-status { background: var(--correct-bg); color: var(--correct); }
  .r-wrong   .r-status { background: var(--wrong-bg);   color: var(--wrong); }

  /* BACK LINK */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    margin-bottom: 32px;
    transition: color 0.12s;
  }
  .back-link:hover { color: var(--accent2); }
</style>
</head>

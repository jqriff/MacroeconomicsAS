<!-- MAIN -->
<main class="main">

  <!-- SELECTOR VIEW -->
  <div class="selector-area" id="selectorArea">
    <a href="index.html" class="back-link">← Back to Study Notes</a>
    <div class="hero">
      <div class="hero-label">Knowledge Test</div>
      <h1>Test Your<br><em>Understanding</em></h1>
      <p>Select one or more topics below then start the quiz. You'll get a mix of multiple choice, true/false, and short answer questions — with full feedback at the end.</p>
    </div>

    <div class="selector-label">Choose Topics</div>
    <div class="topic-grid" id="topicGrid"></div>

    <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
      <button class="start-btn" id="startBtn" disabled onclick="startQuiz()">
        Start Quiz →
      </button>
      <button class="start-btn" style="background:var(--bg3);color:var(--ink2);border:1px solid var(--border);" onclick="selectAll()">Select All</button>
    </div>
  </div>

  <!-- QUIZ VIEW -->
  <div class="quiz-area" id="quizArea">
    <div class="quiz-header">
      <div class="quiz-header-left">
        <h2 id="quizTitle">Topic Quiz</h2>
        <p id="quizSubtitle"></p>
      </div>
      <div class="progress-wrap">
        <div class="progress-label" id="progressLabel">1 / 10</div>
        <div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>
      </div>
    </div>

    <div id="questionContainer"></div>

    <div class="q-nav">
      <button class="nav-btn" id="prevBtn" onclick="prevQ()" disabled>← Previous</button>
      <button class="nav-btn primary" id="nextBtn" onclick="nextQ()">Next →</button>
    </div>
  </div>

  <!-- RESULTS VIEW -->
  <div id="resultsArea" style="display:none;">
    <div class="results-card" id="resultsCard"></div>
    <div class="review-list" id="reviewList"></div>
  </div>

</main>

<script>
// ─── QUESTION BANK ────────────────────────────────────────────────────────────
// Format: { type: 'mc'|'tf'|'short', q, options (mc), answer, explanation }
const QUESTIONS = {

  m1: {
    title: "M1 — Policy Objectives",
    questions: [
      { type:'mc', q:"Which of the following is NOT a standard macroeconomic policy objective?", options:["Low and stable inflation","Full employment","Maximising corporate profit","Sustainable economic growth"], answer:2, explanation:"The four standard objectives are: low inflation, full employment, economic growth, and balance of payments equilibrium. Maximising corporate profit is a microeconomic/firm-level goal." },
      { type:'tf', q:"The UK government's inflation target is currently set at 2%, as measured by CPI.", answer:true, explanation:"The Bank of England has a 2% CPI inflation target set by the government. Missing the target by more than 1% either way requires a letter to the Chancellor." },
      { type:'mc', q:"A conflict between policy objectives occurs when:", options:["Unemployment and inflation both fall","Reducing inflation leads to higher unemployment","GDP growth and employment rise together","Tax revenues increase with growth"], answer:1, explanation:"The Phillips Curve illustrates the trade-off: policies that reduce inflation (e.g. raising interest rates) tend to slow the economy and increase unemployment." },

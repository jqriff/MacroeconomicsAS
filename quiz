let activeQuestions = [];
let currentQ = 0;
let userAnswers = []; // { answered: bool, correct: bool, userAns, qRef }

// ─── BUILD TOPIC GRID ─────────────────────────────────────────────────────────
function buildTopicGrid() {
  const grid = document.getElementById('topicGrid');
  Object.entries(QUESTIONS).forEach(([key, topic]) => {
    const btn = document.createElement('button');
    btn.className = 'topic-btn';
    btn.dataset.key = key;
    btn.innerHTML = `
      <span class="t-num">${key.toUpperCase()}</span>
      <div class="t-name">${topic.title.replace(/^M\d+ — /, '')}</div>
      <div class="t-count">${topic.questions.length} questions</div>
    `;
    btn.addEventListener('click', () => toggleTopic(key, btn));
    grid.appendChild(btn);
  });
}

function toggleTopic(key, btn) {
  const idx = selectedTopics.indexOf(key);
  if (idx === -1) { selectedTopics.push(key); btn.classList.add('selected'); }
  else { selectedTopics.splice(idx, 1); btn.classList.remove('selected'); }
  document.getElementById('startBtn').disabled = selectedTopics.length === 0;
}

function selectAll() {
  const allKeys = Object.keys(QUESTIONS);
  const allSelected = selectedTopics.length === allKeys.length;
  document.querySelectorAll('.topic-btn').forEach(btn => {
    const key = btn.dataset.key;
    if (allSelected) { btn.classList.remove('selected'); }
    else { btn.classList.add('selected'); }
  });
  selectedTopics = allSelected ? [] : [...allKeys];
  document.getElementById('startBtn').disabled = selectedTopics.length === 0;
}

// ─── START QUIZ ───────────────────────────────────────────────────────────────
function startQuiz() {
  activeQuestions = [];
  selectedTopics.forEach(key => {
    QUESTIONS[key].questions.forEach(q => activeQuestions.push({ ...q, _topic: key }));
  });
  // Shuffle
  for (let i = activeQuestions.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [activeQuestions[i], activeQuestions[j]] = [activeQuestions[j], activeQuestions[i]];
  }
  userAnswers = activeQuestions.map(() => ({ answered: false, correct: null, userAns: null }));
  currentQ = 0;

  document.getElementById('selectorArea').classList.add('hidden');
  document.getElementById('quizArea').classList.add('active');

  const titles = selectedTopics.length === 1
    ? QUESTIONS[selectedTopics[0]].title
    : `${selectedTopics.length} Topics`;
  document.getElementById('quizTitle').textContent = titles;
  document.getElementById('quizSubtitle').textContent = `${activeQuestions.length} questions — Mix of multiple choice, true/false & short answer`;

  renderQuestion();
}

// ─── RENDER QUESTION ──────────────────────────────────────────────────────────
function renderQuestion() {
  const q = activeQuestions[currentQ];
  const ua = userAnswers[currentQ];
  const total = activeQuestions.length;

  document.getElementById('progressLabel').textContent = `${currentQ + 1} / ${total}`;
  document.getElementById('progressFill').style.width = `${((currentQ + 1) / total) * 100}%`;

  document.getElementById('prevBtn').disabled = currentQ === 0;

  const isLast = currentQ === total - 1;
  const nextBtn = document.getElementById('nextBtn');
  nextBtn.textContent = isLast ? 'Finish →' : 'Next →';

  let html = `
    <div class="question-card">
      <div class="q-meta">
        <span class="q-num">Q${currentQ + 1}</span>
        <span class="q-type-badge ${q.type}">${q.type === 'mc' ? 'Multiple Choice' : q.type === 'tf' ? 'True / False' : 'Short Answer'}</span>
      </div>
      <div class="q-text">${q.q}</div>
  `;

  if (q.type === 'mc') {
    const letters = ['A','B','C','D'];
    html += `<ul class="options-list">`;
    q.options.forEach((opt, i) => {
      let cls = '';
      if (ua.answered) {
        if (i === q.answer) cls = 'correct';
        else if (i === ua.userAns) cls = 'wrong';
      }
      html += `<li><button class="option-btn ${cls}" ${ua.answered ? 'disabled' : ''} onclick="answerMC(${i})">
        <span class="opt-letter">${letters[i]}</span>${opt}
      </button></li>`;
    });
    html += `</ul>`;

  } else if (q.type === 'tf') {
    const trueClass  = ua.answered ? (q.answer === true  ? 'correct' : ua.userAns === true  ? 'wrong' : '') : '';
    const falseClass = ua.answered ? (q.answer === false ? 'correct' : ua.userAns === false ? 'wrong' : '') : '';
    html += `<div class="tf-options">
      <button class="tf-btn ${trueClass}" ${ua.answered ? 'disabled' : ''} onclick="answerTF(true)">True</button>
      <button class="tf-btn ${falseClass}" ${ua.answered ? 'disabled' : ''} onclick="answerTF(false)">False</button>
    </div>`;

  } else {
    html += `<div class="short-answer-wrap">
      <textarea class="short-input" id="shortInput" placeholder="Type your answer here…" ${ua.answered ? 'disabled' : ''}>${ua.userAns || ''}</textarea>
      ${!ua.answered ? `<button class="check-btn" onclick="answerShort()">Check Answer</button>` : ''}
    </div>`;
  }

  // Feedback
  if (ua.answered) {
    if (q.type === 'short') {
      html += `<div class="feedback-box show wrong-fb">
        <div class="fb-label">Model Answer</div>
        <div class="model-answer">${q.answer}</div>
      </div>`;
    } else {
      const correct = ua.correct;
      html += `<div class="feedback-box show ${correct ? 'correct-fb' : 'wrong-fb'}">
        <div class="fb-label">${correct ? '✓ Correct' : '✗ Incorrect'}</div>
        <div class="model-answer">${q.explanation}</div>
      </div>`;
    }
  }

  html += `</div>`;
  document.getElementById('questionContainer').innerHTML = html;
}

// ─── ANSWER HANDLERS ──────────────────────────────────────────────────────────
function answerMC(i) {
  const q = activeQuestions[currentQ];
  userAnswers[currentQ] = { answered: true, correct: i === q.answer, userAns: i };
  renderQuestion();
}
function answerTF(val) {
  const q = activeQuestions[currentQ];
  userAnswers[currentQ] = { answered: true, correct: val === q.answer, userAns: val };
  renderQuestion();
}
function answerShort() {
  const val = document.getElementById('shortInput').value.trim();
  if (!val) return;
  userAnswers[currentQ] = { answered: true, correct: null, userAns: val };
  renderQuestion();
}

// ─── NAVIGATION ───────────────────────────────────────────────────────────────
function nextQ() {
  if (currentQ < activeQuestions.length - 1) { currentQ++; renderQuestion(); }
  else showResults();
}
function prevQ() {
  if (currentQ > 0) { currentQ--; renderQuestion(); }
}

// ─── RESULTS ─────────────────────────────────────────────────────────────────
function showResults() {
  document.getElementById('quizArea').classList.remove('active');
  document.getElementById('resultsArea').style.display = 'block';

  const answered = userAnswers.filter(a => a.answered);
  const gradable  = userAnswers.filter(a => a.correct !== null);
  const correct   = gradable.filter(a => a.correct).length;
  const total     = gradable.length;
  const shortCount = userAnswers.filter(a => activeQuestions[userAnswers.indexOf(a)]?.type === 'short').length;
  const pct = total > 0 ? Math.round((correct / total) * 100) : null;

  const circum = 2 * Math.PI * 52;
  const offset = pct !== null ? circum - (pct / 100) * circum : circum;
  const ringClass = pct === null ? '' : pct >= 70 ? 'high' : pct < 40 ? 'low' : '';

  let grade = '', gradeColor = 'var(--ink2)';
  if (pct === null) { grade = 'Self-assessed'; }
  else if (pct >= 80) { grade = 'Excellent'; gradeColor = 'var(--correct)'; }
  else if (pct >= 60) { grade = 'Good'; gradeColor = 'var(--accent2)'; }
  else if (pct >= 40) { grade = 'Keep Revising'; gradeColor = 'var(--accent)'; }
  else { grade = 'Needs Work'; gradeColor = 'var(--wrong)'; }

  document.getElementById('resultsCard').innerHTML = `
    <div class="score-ring">
      <svg viewBox="0 0 120 120">
        <circle class="ring-bg" cx="60" cy="60" r="52"/>
        <circle class="ring-fill ${ringClass}" cx="60" cy="60" r="52"
          stroke-dasharray="${circum}"
          stroke-dashoffset="${pct !== null ? offset : 0}"
          id="ringFill"/>
      </svg>
      <div class="score-text">${pct !== null ? pct + '%' : '—'}</div>
    </div>
    <div class="results-title">Quiz Complete</div>
    <div class="results-sub" style="color:${gradeColor};font-weight:600;font-size:16px;margin-bottom:8px;">${grade}</div>
    <div class="results-sub">You answered ${answered.length} of ${activeQuestions.length} questions</div>
    <div class="results-breakdown">
      <div class="rb-item"><div class="rb-val" style="color:var(--correct)">${correct}</div><div class="rb-label">Correct</div></div>
      <div class="rb-item"><div class="rb-val" style="color:var(--wrong)">${total - correct}</div><div class="rb-label">Incorrect</div></div>
      <div class="rb-item"><div class="rb-val" style="color:var(--muted)">${shortCount}</div><div class="rb-label">Self-Marked</div></div>
    </div>
    <div class="results-actions">
      <button class="nav-btn primary" onclick="retryQuiz()">Retake Quiz</button>
      <button class="nav-btn" onclick="backToSelector()">Choose New Topics</button>
      <a href="index.html" class="nav-btn" style="text-decoration:none;display:inline-flex;align-items:center;">Back to Notes</a>
    </div>
  `;

  // Review
  let reviewHtml = `<div class="review-label">Full Review</div>`;
  activeQuestions.forEach((q, i) => {
    const ua = userAnswers[i];
    if (!ua.answered) return;
    const isShort = q.type === 'short';
    const resultClass = isShort ? 'r-wrong' : (ua.correct ? 'r-correct' : 'r-wrong');
    const statusLabel = isShort ? 'Self-mark' : (ua.correct ? 'Correct' : 'Incorrect');

    let yourAns = '';
    if (q.type === 'mc') yourAns = q.options[ua.userAns] || '—';
    else if (q.type === 'tf') yourAns = ua.userAns === true ? 'True' : 'False';
    else yourAns = ua.userAns || '—';

    let correctAns = '';
    if (q.type === 'mc') correctAns = q.options[q.answer];
    else if (q.type === 'tf') correctAns = q.answer ? 'True' : 'False';
    else correctAns = q.answer;

    reviewHtml += `
      <div class="review-item ${resultClass}">
        <span class="r-status">${statusLabel}</span>
        <div class="r-q">Q${i+1}: ${q.q}</div>
        <div class="r-your"><strong>Your answer:</strong> ${yourAns}</div>
        ${!ua.correct || isShort ? `<div class="r-correct-ans"><strong>${isShort ? 'Model answer' : 'Correct answer'}:</strong> ${correctAns}</div>` : ''}
        ${!isShort ? `<div style="font-size:13px;color:var(--muted);margin-top:6px;">${q.explanation}</div>` : ''}
      </div>
    `;
  });
  document.getElementById('reviewList').innerHTML = reviewHtml;

  // Animate ring
  setTimeout(() => {
    const ring = document.getElementById('ringFill');
    if (ring) ring.style.strokeDashoffset = offset;
  }, 100);
}

function retryQuiz() {
  document.getElementById('resultsArea').style.display = 'none';
  document.getElementById('reviewList').innerHTML = '';
  startQuiz();
}

function backToSelector() {
  document.getElementById('resultsArea').style.display = 'none';
  document.getElementById('reviewList').innerHTML = '';
  document.getElementById('selectorArea').classList.remove('hidden');
  currentQ = 0; activeQuestions = []; userAnswers = [];
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
buildTopicGrid();
</script>
</body>
</html>
